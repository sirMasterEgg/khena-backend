# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Server
PORT=3000

# Storage (S3-compatible: AWS S3, Cloudflare R2, MinIO)
# Pilih provider: s3 | r2 | minio  (gcs belum diimplementasikan)
STORAGE_PROVIDER=s3
S3_REGION=us-east-1
S3_BUCKET=khena-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# Upload chunked (S3 Multipart): ukuran tiap part dalam byte.
# Minimal 5 MB (batasan S3), default 10 MB.
MULTIPART_PART_SIZE=10485760

# Auth
JWT_SECRET=ganti-dengan-random-string-panjang
ACCESS_TOKEN_TTL=900            # detik (15 menit)
REFRESH_TOKEN_TTL=1209600       # detik (14 hari)

# CSRF (signed double submit)
CSRF_SECRET=ganti-dengan-random-string-panjang-berbeda

# Pre-session (stateless signed cookie untuk mitigasi login CSRF)
PRE_SESSION_SECRET=ganti-dengan-random-string-panjang-lain
PRE_SESSION_TTL=1800            # detik (30 menit)

# Cookie
COOKIE_SECURE=false             # true di production (HTTPS)
COOKIE_DOMAIN=localhost